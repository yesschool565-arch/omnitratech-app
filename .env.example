# Frontend Environment Configuration

# Backend API URL
# Development: http://localhost:3000/api (for local development)
# Production: https://your-backend-domain.com/api (deployed backend)
VITE_API_URL=http://localhost:3000/api

# Gemini API Key (optional, for AI features)
GEMINI_API_KEY=

# NOTE FOR DEPLOYMENT:
# 1. Update VITE_API_URL to your backend domain before deploying
# 2. The /api prefix is required for all API requests
# 3. All static assets (like noise.svg) are served through /api/assets/
#
# VERCEL DEPLOYMENT:
# - Set VITE_API_URL in Vercel Environment Variables
# - Example: https://omnitratech-backend.onrender.com/api
#
# LOCAL DEVELOPMENT:
# - Frontend runs on http://localhost:5175
# - Backend runs on http://localhost:3000
# - API requests proxy to http://localhost:3000/api
